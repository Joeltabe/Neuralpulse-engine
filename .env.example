# ============================================================
# NeuralPulse Engine - Configuration
# ============================================================
# Copy this to .env for local development:
#   cp .env.example .env
# For production, use .env.production and adjust values.
# ============================================================

# --- Runtime ---
HOST=0.0.0.0
PORT=8000
RELOAD=true
LOG_LEVEL=info
ENVIRONMENT=development

# --- TRIBE v2 Engine ---
USE_REAL_TRIBE=false
TRIBE_CACHE_DIR=./cache
TRIBE_MODEL_NAME=facebook/tribev2
TRIBE_API_URL=https://thesilenthowler029-tribe-v2-api.hf.space
DEVICE=cpu

# --- File Storage ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=500

# --- Database ---
# Default: Neon PostgreSQL (async with asyncpg)
DATABASE_URL=postgresql+asyncpg://neondb_owner:npg_whCHN2qzY8Km@ep-holy-forest-aqly3mmb-pooler.c-8.us-east-1.aws.neon.tech/Poker?sslmode=require
# Set to "true" to force SQLite instead of PostgreSQL
USE_SQLITE=false

# PostgreSQL Connection Pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_ECHO=false

# --- Redis (cache, rate limiting) ---
REDIS_URL=

# --- JWT Authentication ---
# Change this to a random 64-char hex string in production!
JWT_SECRET=change-this-to-a-random-secret-in-production
TOKEN_EXPIRE_MINUTES=1440

# --- Stripe (optional - for token purchases) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
FRONTEND_URL=http://localhost:8000

# --- Rate Limiting ---
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SEC=60
RATE_LIMIT_AUTH_REQUESTS=20
RATE_LIMIT_AUTH_WINDOW_SEC=60
RATE_LIMIT_ANALYSIS_REQUESTS=10
RATE_LIMIT_ANALYSIS_WINDOW_SEC=60

# --- CORS ---
# Comma-separated list of allowed origins
CORS_ORIGINS=*

# --- Trusted Hosts ---
TRUSTED_HOSTS=*

# --- Sentry (optional) ---
SENTRY_DSN=
